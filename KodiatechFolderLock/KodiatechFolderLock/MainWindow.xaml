<Window x:Class="KodiatechFolderLock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KodiatechFolderLock"
        mc:Ignorable="d"
        Title="Connexion" Height="220" Width="320" ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Bienvenue" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,5,0,0">
            <TextBlock Text="Nom d'utilisateur" />
            <TextBox x:Name="txtUsername" Width="250" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Vertical" Margin="0,10,0,0">
            <TextBlock Text="Mot de passe" />
            <PasswordBox x:Name="pwdPassword" Width="250" />
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="btnLogin" Width="100" Click="ButtonAddName_Click">Se connecter</Button>
        </StackPanel>
    </Grid>
</Window>
